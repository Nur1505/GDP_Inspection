<launch>
  <group ns="rtabmap">

    <!-- RTAB-Map's own RGB-D odometry -->
    <node pkg="rtabmap_ros" type="rgbd_odometry" name="rgbd_odometry" output="screen">
      <param name="frame_id" value="base_link"/>
      <param name="odom_frame_id" value="odom"/>
      <param name="subscribe_depth" value="true"/>
      <param name="approx_sync" value="true"/>
      <param name="publish_tf" value="true"/>

      <!-- start conservative -->
      <param name="Odom/GuessMotion" value="true"/>
      <param name="Odom/InlierDistance" value="0.1"/>
      <param name="Vis/MinInliers" value="8"/>
      <param name="Vis/MaxFeatures" value="1500"/>

      <remap from="rgb/image" to="/d435/color/image_raw"/>
      <remap from="depth/image" to="/d435/depth/image_raw"/>
      <remap from="rgb/camera_info" to="/d435/color/camera_info"/>
      <remap from="odom" to="/vo"/>
    </node>

    <!-- Mapping -->
    <node pkg="rtabmap_ros" type="rtabmap" name="rtabmap" output="screen" args="--delete_db_on_start">
      <param name="frame_id" value="base_link"/>
      <param name="subscribe_depth" value="true"/>
      <param name="approx_sync" value="true"/>

      <remap from="rgb/image" to="/d435/color/image_raw"/>
      <remap from="depth/image" to="/d435/depth/image_raw"/>
      <remap from="rgb/camera_info" to="/d435/color/camera_info"/>
      <remap from="odom" to="/vo"/>
    </node>

    <node pkg="rtabmap_ros" type="rtabmapviz" name="rtabmapviz" output="screen">
      <param name="frame_id" value="base_link"/>
      <param name="subscribe_depth" value="true"/>
      <param name="approx_sync" value="true"/>

      <remap from="rgb/image" to="/d435/color/image_raw"/>
      <remap from="depth/image" to="/d435/depth/image_raw"/>
      <remap from="rgb/camera_info" to="/d435/color/camera_info"/>
      <remap from="odom" to="/vo"/>
    </node>

  </group>
</launch>