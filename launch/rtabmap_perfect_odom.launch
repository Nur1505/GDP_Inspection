<launch>
  <group ns="rtabmap">

    <node pkg="rtabmap_ros" type="rgbd_sync" name="rgbd_sync" output="screen">
      <param name="approx_sync" value="true"/>
      <param name="queue_size" value="50"/>
      <remap from="rgb/image" to="/rgbd/color/image_raw"/>
      <remap from="depth/image" to="/rgbd/depth/image_raw"/>
      <remap from="rgb/camera_info" to="/rgbd/color/camera_info"/>
      <remap from="rgbd_image" to="/rgbd_image"/>
    </node>

    <node pkg="rtabmap_ros" type="rtabmap" name="rtabmap" output="screen" args="--delete_db_on_start">
      <param name="frame_id" value="base_link"/>
      <param name="subscribe_rgbd" value="true"/>
      <param name="queue_size" value="50"/>

      <param name="Rtabmap/DetectionRate" value="10"/>
      <param name="RGBD/LinearUpdate" value="0.02"/>
      <param name="RGBD/AngularUpdate" value="0.02"/>
<!-- 
      <param name="RGBD/LinearUpdate" value="0.10"/>
      <param name="RGBD/AngularUpdate" value="0.10"/>

      <param name="Kp/MaxFeatures" value="600"/>
      <param name="Vis/MinInliers" value="8"/>
      <param name="Odom/GuessMotion" value="true"/>
      <param name="Grid/RangeMax" value="4.0"/> -->
      <param name="Mem/IncrementalMemory" value="true"/>
<param name="RGBD/CreateOccupancyGrid" value="true"/>
      <remap from="rgbd_image" to="/rgbd_image"/>
      <remap from="odom" to="/odom"/>
    </node>

    <node pkg="rtabmap_ros" type="rtabmapviz" name="rtabmapviz" output="screen">
      <param name="frame_id" value="base_link"/>
      <param name="subscribe_rgbd" value="true"/>
      <param name="queue_size" value="50"/>
       <remap from="rgb/image" to="/rgbd/color/image_raw"/>
      <remap from="depth/image" to="/rgbd/depth/image_raw"/>
      <remap from="rgb/camera_info" to="/rgbd/color/camera_info"/>
      <remap from="rgbd_image" to="/rgbd_image"/>
    </node>

  </group>
</launch>